generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User{
  id        String       @id @default(uuid())
  username  String    @unique
  email     String
  password  String
  name      String
  rooms     Room[] //one to many
  chats     Chat[]

}

model Room{
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  createdAt  DateTime @default(now())
  adminId    String
  admin      User     @relation(fields:[adminId],references:[id])//one to many
  chats      Chat[]//one to many
}

model Chat{
  id        Int       @id @default(autoincrement())
  roomId    Int
  message   String
  userId    String
  room      Room     @relation(fields:[roomId],references:[id])
  user      User     @relation(fields:[userId],references:[id])

}